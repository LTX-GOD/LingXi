# LingXi public edition environment template
# Leave competition/forum URLs blank to start in standby mode.

# --- Competition platform (optional) ---
COMPETITION_BASE_URL=
COMPETITION_API_BASE_URL=
# COMPETITION_SERVER_HOST=
# COMPETITION_SERVER_HOST_FALLBACK=
AGENT_TOKEN=replace-with-agent-token

# --- Forum extension (private, disabled by default) ---
FORUM_ENABLED=false
SERVER_HOST=
SERVER_HOST_FALLBACK=
# AGENT_BEARER_TOKEN=replace-with-forum-token

# --- Main LLM providers ---
MAIN_LLM_PROVIDER=openai
ADVISOR_LLM_PROVIDER=anthropic
FORUM_LLM_PROVIDER=openai

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=replace-with-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=replace-with-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4o-mini

OPENAI_FALLBACK_BASE_URL=
OPENAI_FALLBACK_API_KEY=
OPENAI_FALLBACK_MODEL=

MAIN_FALLBACK_BASE_URL=
MAIN_FALLBACK_API_KEY=
MAIN_FALLBACK_MODEL=
ADVISOR_FALLBACK_BASE_URL=
ADVISOR_FALLBACK_API_KEY=
ADVISOR_FALLBACK_MODEL=
FORUM_FALLBACK_BASE_URL=
FORUM_FALLBACK_API_KEY=
FORUM_FALLBACK_MODEL=

FORUM_LLM_BASE_URL=
FORUM_LLM_API_KEY=
FORUM_LLM_MODEL=

SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=replace-with-siliconflow-key
SILICONFLOW_MODEL=Qwen/Qwen3-32B

# --- Docker / Kali ---
DOCKER_ENABLED=true
DOCKER_CONTAINER_NAME=kali-pentest
DDDD2_PATH=./dddd2

# --- Sliver extension (private, disabled by default) ---
SLIVER_ENABLED=false
SLIVER_CLIENT_PATH=./bin/sliver-client
SLIVER_CLIENT_CONFIG=./sliver-config
SLIVER_CLIENT_ROOT_DIR=./sliver-workdir
SLIVER_AUTO_ENABLE_IF_PRESENT=false

# --- Agent runtime ---
MAX_ATTEMPTS=70
INITIAL_ATTEMPT_BUDGET=50
RETRY_ATTEMPT_BUDGET_STEP=10
MAX_CONCURRENT_TASKS=8
SINGLE_TASK_TIMEOUT=1800
MAX_RETRIES=4
RETRY_BACKOFF_SECONDS=60
FETCH_INTERVAL_SECONDS=600
SCHEDULE_TICK_SECONDS=5
MAIN_BATTLE_DEMO_ALLOWLIST=
LING_XI_UNSAFE_RAW_LOGS=0
LING_XI_IDLE_FETCH_SECONDS=3
LING_XI_BUSY_FETCH_SECONDS=30

# --- Advisor / control ---
CONSECUTIVE_FAILURES_THRESHOLD=3
ADVISOR_CONSULTATION_INTERVAL=0
ATTEMPT_HISTORY_LIMIT=3
ENABLE_ROLE_SWAP_RETRY=true
TOOL_LOOP_BREAK_THRESHOLD=20
ADVISOR_NO_TOOL_ROUNDS_THRESHOLD=2

# --- SDK ---
SDK_MODEL=claude-3-5-sonnet-latest
SDK_ADVISOR_MODEL=claude-3-5-haiku-latest
SDK_PERMISSION_MODE=bypassPermissions

# --- Optional knowledge service ---
KNOWLEDGE_SERVICE_ENABLED=false
KNOWLEDGE_SERVICE_HOST=127.0.0.1
KNOWLEDGE_SERVICE_PORT=8791

# --- Auto hinting ---
AUTO_FETCH_HINT=false
AUTO_HINT_ON_RETRY_LEVEL=2
